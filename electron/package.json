{
  "name": "restaurante-admin-desktop",
  "version": "1.0.0",
  "description": "Sistema Administrativo Restaurante - App Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.restaurante.admin",
    "productName": "RestAdmin",
    "directories": { "output": "dist" },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
